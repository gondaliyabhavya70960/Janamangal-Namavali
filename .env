# Build-time public configuration. Committed on purpose.
#
# A Google OAuth *web* Client ID is NOT a secret — it is meant to be embedded in
# client-side code and only works from the "Authorized JavaScript origins" you
# register in Google Cloud Console. To override per-environment, set
# NEXT_PUBLIC_GOOGLE_CLIENT_ID in your hosting provider's env vars instead.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=216659876620-5eu3jne1uo2k1549j5mf1p7pu52g067a.apps.googleusercontent.com
